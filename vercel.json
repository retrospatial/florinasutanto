{
	"buildCommand": "pnpm run build",
	"framework": "sveltekit",
	"installCommand": "pnpm install",

	"rewrites": [
		{
			"source": "/animorphs/:path*",
			"destination": "https://retrospatial.github.io/animorphs/:path*"
		},
		{
			"source": "/tumblr-fandometrics/:path*",
			"destination": "https://retrospatial.github.io/tumblr-fandometrics/:path*"
		},
		{
			"source": "/buffy-podcasts/:path*",
			"destination": "https://retrospatial.github.io/buffy-podcasts/:path*"
		}
	]
}
